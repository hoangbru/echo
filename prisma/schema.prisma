// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User roles enum
enum UserRole {
  USER
  ARTIST
  ADMIN
}

// Artist request status
enum ArtistRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// Repeat modes for player
enum RepeatMode {
  OFF
  ALL
  ONE
}

// ==================== Auth & Users ====================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  fullName  String?
  bio       String?
  avatar    String?  
  role      UserRole @default(USER)
  
  // Premium subscription
  isPremium          Boolean   @default(false)
  premiumExpiresAt   DateTime?
  
  // Artist info (if role is ARTIST)
  artistProfile      ArtistProfile?
  
  // User activity
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  lastLoginAt        DateTime?
  
  // Relations
  playlists          Playlist[]
  playlistCollaborators PlaylistCollaborator[]
  favorites          Favorite[]
  likedAlbums        AlbumLike[]
  likedTracks        TrackLike[]
  streamHistory      StreamHistory[]
  notificationSettings NotificationSettings?
  followers          Follow[] @relation("followers")
  following          Follow[] @relation("following")
  comments           Comment[]
  reviews            Review[]
  artistRequests     ArtistRequest[]
  
  @@index([email])
  @@index([username])
  @@index([role])
}

// ==================== Artists ====================

model ArtistProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  bio         String?
  profileImage String?  
  bannerImage String?  
  
  // Artist stats
  totalTracks    Int   @default(0)
  totalAlbums    Int   @default(0)
  totalFollowers Int   @default(0)
  totalStreams   Int   @default(0)
  
  // Verification
  isVerified     Boolean @default(false)
  verifiedAt     DateTime?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Relations
  albums         Album[]
  tracks         Track[]
  
  @@index([userId])
  @@index([isVerified])
}

model ArtistRequest {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  status    ArtistRequestStatus   @default(PENDING)
  reason    String?               // Why they want to become artist
  
  reviewedAt    DateTime?
  reviewedBy    String?            // Admin who reviewed
  reviewComment String?
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ==================== Music Content ====================

model Genre {
  id    String  @id @default(cuid())
  name  String  @unique
  description String?
  color String? @db.VarChar(7)
  icon  String?
  
  createdAt DateTime @default(now())
  
  albums  Album[]
  tracks  Track[]
  
  @@index([name])
}

model Album {
  id          String  @id @default(cuid())
  title       String
  artistId    String
  artist      ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  
  description String?
  coverImage  String?  
  releaseDate DateTime @default(now())
  
  genreId     String?
  genre       Genre?   @relation(fields: [genreId], references: [id])
  
  // Stats
  totalTracks Int     @default(0)
  totalStreams Int    @default(0)
  rating      Float?
  
  // Visibility
  isPublished Boolean @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  tracks      Track[]
  likes       AlbumLike[]
  reviews     Review[]
  
  @@index([artistId])
  @@index([genreId])
  @@index([releaseDate])
  @@index([isPublished])
}

model Track {
  id          String  @id @default(cuid())
  title       String
  artistId    String
  artist      ArtistProfile @relation(fields: [artistId], references: [id], onDelete: Cascade)
  
  albumId     String?
  album       Album?  @relation(fields: [albumId], references: [id], onDelete: SetNull)
  
  genreId     String?
  genre       Genre?  @relation(fields: [genreId], references: [id])
  
  // Audio file
  audioUrl    String  
  duration    Int     // Duration in seconds
  
  // Metadata
  isrc        String?  // International Standard Recording Code
  lyrics      String?  @db.Text
  previewUrl  String?  
  
  // Stats
  totalStreams Int @default(0)
  totalDownloads Int @default(0)
  rating      Float?
  
  // Visibility & Publishing
  isPublished Boolean @default(false)
  isExplicit  Boolean @default(false)
  
  // Release info
  releaseDate DateTime @default(now())
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  likes       TrackLike[]
  streamHistory StreamHistory[]
  playlistItems PlaylistItem[]
  comments    Comment[]
  reviews     Review[]
  recommendations TrackRecommendation[] @relation("recommendedTrack")
  recommendedIn   TrackRecommendation[] @relation("relatedTrack")
  
  favorite Favorite[]

  @@index([artistId])
  @@index([albumId])
  @@index([genreId])
  @@index([releaseDate])
  @@index([isPublished])
}

// ==================== Playlists ====================

model Playlist {
  id          String  @id @default(cuid())
  name        String
  description String?
  
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  coverImage  String?  
  isPublic    Boolean  @default(false)
  
  // Stats
  totalTracks Int     @default(0)
  totalStreams Int    @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  items       PlaylistItem[]
  collaborators PlaylistCollaborator[]
  
  @@index([userId])
  @@index([isPublic])
  @@index([createdAt])
}

model PlaylistItem {
  id          String  @id @default(cuid())
  playlistId  String
  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  
  trackId     String
  track       Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  
  position    Int      // Order in playlist
  addedAt     DateTime @default(now())
  
  @@unique([playlistId, trackId])
  @@index([playlistId])
  @@index([trackId])
}

model PlaylistCollaborator {
  id          String  @id @default(cuid())
  playlistId  String
  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role        String  @default("EDITOR")
  addedAt     DateTime @default(now())
  
  @@unique([playlistId, userId])
  @@index([playlistId])
  @@index([userId])
}

// ==================== User Interactions ====================

model Favorite {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  trackId     String
  track       Track   @relation(fields: [trackId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([userId, trackId])
  @@index([userId])
  @@index([trackId])
}

model TrackLike {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  trackId     String
  track       Track   @relation(fields: [trackId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([userId, trackId])
  @@index([userId])
  @@index([trackId])
}

model AlbumLike {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  albumId     String
  album       Album   @relation(fields: [albumId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([userId, albumId])
  @@index([userId])
  @@index([albumId])
}

model Follow {
  id          String  @id @default(cuid())
  followerId  String
  follower    User    @relation("followers", fields: [followerId], references: [id], onDelete: Cascade)
  
  followingId String
  following   User    @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ==================== Streaming & Analytics ====================

model StreamHistory {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  trackId     String
  track       Track   @relation(fields: [trackId], references: [id], onDelete: Cascade)
  
  streamedAt  DateTime @default(now())
  duration    Int?     // How long they listened (seconds)
  progress    Int?     // Where they stopped (percentage)
  
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([trackId])
  @@index([streamedAt])
}

model TrackRecommendation {
  id          String  @id @default(cuid())
  trackId     String
  track       Track   @relation("recommendedTrack", fields: [trackId], references: [id], onDelete: Cascade)
  
  relatedTrackId String
  relatedTrack   Track   @relation("relatedTrack", fields: [relatedTrackId], references: [id], onDelete: Cascade)
  
  score       Float   @default(0)
  reason      String? // Why it's recommended
  
  createdAt   DateTime @default(now())
  
  @@unique([trackId, relatedTrackId])
  @@index([trackId])
  @@index([relatedTrackId])
  @@index([score])
}

// ==================== Social & Content ====================

model Comment {
  id          String  @id @default(cuid())
  content     String  @db.Text
  
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  trackId     String
  track       Track   @relation(fields: [trackId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([trackId])
  @@index([createdAt])
}

model Review {
  id          String  @id @default(cuid())
  content     String  @db.Text
  rating      Int     // 1-5 stars
  
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  trackId     String?
  track       Track?  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  
  albumId     String?
  album       Album?  @relation(fields: [albumId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([userId, trackId, albumId])
  @@index([userId])
  @@index([trackId])
  @@index([albumId])
  @@index([rating])
}

// ==================== Notifications ====================

model NotificationSettings {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Notification preferences
  emailNotifications    Boolean @default(true)
  pushNotifications     Boolean @default(true)
  newReleaseNotifications Boolean @default(true)
  followerNotifications Boolean @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== Admin & Content Management ====================

model AdminAuditLog {
  id          String  @id @default(cuid())
  adminId     String
  
  action      String  // e.g., "DELETE_TRACK", "APPROVE_ARTIST", "SUSPEND_USER"
  targetType  String  // "USER", "TRACK", "ALBUM", "ARTIST_REQUEST"
  targetId    String
  targetName  String?
  
  changes     String?  // Snapshot of what changed
  
  createdAt   DateTime @default(now())
  
  @@index([adminId])
  @@index([action])
  @@index([targetType])
  @@index([createdAt])
}

model ContentReport {
  id          String  @id @default(cuid())
  reporterId  String
  
  reportType  String  // "TRACK", "ALBUM", "USER", "COMMENT"
  targetId    String
  targetName  String?
  
  reason      String
  description String? @db.Text
  
  status      String  @default("PENDING") // PENDING, UNDER_REVIEW, RESOLVED, DISMISSED
  resolvedAt  DateTime?
  resolvedBy  String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([reporterId])
  @@index([status])
  @@index([createdAt])
}
